# Runtime uploads and generated files (these should be volumes in production)
server/uploads/
server/renders/
server/templates/

# But keep the font directory structure (empty directories)
!server/font/
server/font/**/*

# Keep secret directory structure but ignore actual secret files
!server/secret/
server/secret/*.json

# Keep empty directories
!server/uploads/.gitkeep
!server/renders/.gitkeep
!server/templates/.gitkeep