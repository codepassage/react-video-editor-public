/**
 * 🏭 clipCreators.ts - 3단계 Union 타입 클립 생성 팩토리 함수들
 * 
 * 타입 안전하고 편리한 클립 생성을 위한 팩토리 패턴 구현 파일입니다.
 * 8가지 클립 타입을 쉽고 안전하게 생성할 수 있는 헬퍼 함수들을 제공하며,
 * TypeScript의 Union 타입 시스템을 활용하여 컴파일 타임 타입 안전성을 보장합니다.
 * 
 * 주요 기능:
 * - 8가지 클립 타입별 전용 생성 함수 제공
 * - 타입 안전한 클립 생성 (TypeScript Union 타입 활용)
 * - 기본값 자동 설정 및 검증
 * - 필수/선택 속성 구분을 통한 사용 편의성
 * - 일관된 ID 생성 및 이름 관리
 * - 기준 클립 속성 및 부모-자식 관계 지원
 * 
 * 지원되는 클립 타입:
 * - AudioClip: 오디오 전용 (시각적 속성 없음)
 * - VideoClip: 비디오 + 오디오 + 시각적 속성
 * - ImageClip: 이미지 + 시각적 속성
 * - TextClip: 기본 텍스트 + 시각적 속성
 * - SentenceClip: 세그먼트별 스타일링 텍스트
 * - LongSentenceClip: TTS 연동 긴 문장 텍스트
 * - ShapeClip: 복잡한 도형 (SVG 등)
 * - SimpleShapeClip: 단순 도형 (사각형, 원 등)
 * - PolygonShapeClip: 다각형 도형 (별, 하트 등)
 * - SpacerClip: 시간 공간만 차지하는 클립
 * 
 * 팩토리 패턴 장점:
 * - 복잡한 클립 생성 로직 캡슐화
 * - 일관된 기본값 및 검증 로직
 * - 타입별 특화된 속성 설정
 * - 코드 재사용성 및 유지보수성 향상
 * 
 * 사용 예시:
 * ```typescript
 * const audioClip = createAudioClip({
 *   mediaId: 'audio-1',
 *   trackId: 'track-1',
 *   mediaUrl: '/audio.mp3',
 *   startTime: 0,
 *   duration: 10
 * });
 * 
 * const textClip = createTextClip({
 *   mediaId: 'text-1',
 *   trackId: 'track-2',
 *   text: 'Hello World',
 *   startTime: 0,
 *   duration: 5,
 *   x: 100, y: 100,
 *   width: 200, height: 50
 * });
 * ```
 * 
 * 고급 기능:
 * - ID 재사용 지원 (기존 클립 업데이트 시)
 * - 기준 클립 속성 자동 설정
 * - 부모-자식 관계 설정 (LongSentence 시스템)
 * - 타입별 기본 이름 자동 생성
 * - 속성 검증 및 기본값 적용
 * 
 * 관련 모듈:
 * - 2번 모듈: Clip Type System (8가지 클립 타입 정의)
 * - clipTypes.ts: 구체적 클립 타입 인터페이스
 * - clipCore.ts: 기본 클립 속성 및 Union 타입
 * - baseClips.ts: 기준 클립 및 앵커 시스템 연동
 * - 1번 모듈: Timeline System (생성된 클립 배치)
 */

import { 
  AudioClip, 
  VideoClip, 
  ImageClip, 
  TextClip, 
  SentenceClip,
  LongSentenceClip,
  ShapeClip, 
  SimpleShapeClip, 
  PolygonShapeClip,
  SpacerClip,
  NewTimelineClip 
} from './clipTypes';
import { MediaType } from './clipCore';

/**
 * 🆔 고유 ID 생성 함수
 */
function generateClipId(): string {
  return `clip-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
}

/**
 * 🏷️ 클립 타입별 기본 이름 생성
 */
export function getDefaultClipName(mediaType: MediaType, customName?: string): string {
  if (customName && customName.trim()) {
    return customName.trim();
  }

  const defaultNames: Record<MediaType, string> = {
    audio: '오디오 클립',
    video: '비디오 클립', 
    image: '이미지 클립',
    text: '텍스트 클립',
    sentence: 'Sentence 클립',
    longsentence: 'LongSentence 클립',
    shape: '도형 클립',
    simpleShape: '단순 도형',
    polygonShape: '다각형',
    spacer: '스페이서 클립'
  };

  return defaultNames[mediaType] || '클립';
}

/**
 * 🎵 Audio 클립 생성
 * - 시각적 속성 없음
 * - 오디오 속성만 포함
 */
export function createAudioClip(params: {
  mediaId: string;
  trackId: string;
  mediaUrl: string;
  startTime: number;
  duration: number;
  name?: string;
  volume?: number;
  playbackRate?: number;
  id?: string; // 기존 ID를 사용할 수 있도록 추가
  baseClipProperties?: any; // 기준 클립 속성 추가
  parentClipId?: string; // 부모 클립 ID 추가
}): AudioClip {
  const endTime = params.startTime + params.duration;

  const clip: any = {
    // 🔧 기본 속성
    id: params.id || generateClipId(),
    mediaId: params.mediaId,
    trackId: params.trackId,
    name: getDefaultClipName('audio', params.name),
    startTime: params.startTime,
    endTime: endTime,
    duration: params.duration,
    mediaType: 'audio',
    mediaUrl: params.mediaUrl,

    // 🎵 오디오 속성
    volume: params.volume ?? 1.0,
    playbackRate: params.playbackRate ?? 1.0,
  };

  // 🔗 기준 클립 속성 추가
  if (params.baseClipProperties) {
    clip.baseClipProperties = params.baseClipProperties;
  }

  // 🔗 부모 클립 ID 추가
  if (params.parentClipId) {
    clip.parentClipId = params.parentClipId;
  }

  return clip;
}

/**
 * 🎬 Video 클립 생성  
 * - 시각적 + 오디오 속성 모두 포함
 */
export function createVideoClip(params: {
  mediaId: string;
  trackId: string;
  mediaUrl: string;
  startTime: number;
  duration: number;
  name?: string;
  x?: number;
  y?: number;
  width?: number;
  height?: number;
  opacity?: number;
  rotation?: number;
  volume?: number;
  playbackRate?: number;
  // 🎯 이펙트 속성들 추가
  brightness?: number;
  contrast?: number;
  saturation?: number;
  hue?: number;
  blur?: number;
  sepia?: number;
  grayscale?: number;
  fadeIn?: number;
  fadeOut?: number;
  animationType?: string;
  animationDuration?: number;
  animationDelay?: number;
  animationEasing?: string;
  animationLoop?: boolean;
  id?: string; // 기존 ID를 사용할 수 있도록 추가
  baseClipProperties?: any; // 기준 클립 속성 추가
  parentClipId?: string; // 부모 클립 ID 추가
}): VideoClip {
  const endTime = params.startTime + params.duration;

  const clip: any = {
    // 🔧 기본 속성
    id: params.id || generateClipId(),
    mediaId: params.mediaId,
    trackId: params.trackId,
    name: getDefaultClipName('video', params.name),
    startTime: params.startTime,
    endTime: endTime,
    duration: params.duration,
    mediaType: 'video',
    mediaUrl: params.mediaUrl,

    // 🎨 시각적 속성 (기본값 설정)
    x: params.x ?? 0,
    y: params.y ?? 0,
    width: params.width ?? 1920,
    height: params.height ?? 1080,
    opacity: params.opacity ?? 1.0,
    rotation: params.rotation ?? 0,

    // 🎵 오디오 속성
    volume: params.volume ?? 1.0,
    playbackRate: params.playbackRate ?? 1.0,

    // 🎯 이펙트 속성들 추가
    brightness: params.brightness ?? 100,
    contrast: params.contrast ?? 100,
    saturation: params.saturation ?? 100,
    hue: params.hue ?? 0,
    blur: params.blur ?? 0,
    sepia: params.sepia ?? 0,
    grayscale: params.grayscale ?? 0,
    fadeIn: params.fadeIn ?? 0,
    fadeOut: params.fadeOut ?? 0,
    animationType: params.animationType,
    animationDuration: params.animationDuration ?? 1,
    animationDelay: params.animationDelay ?? 0,
    animationEasing: params.animationEasing ?? 'ease',
    animationLoop: params.animationLoop ?? false,
  };

  // 🔗 기준 클립 속성 추가
  if (params.baseClipProperties) {
    clip.baseClipProperties = params.baseClipProperties;
  }

  // 🔗 부모 클립 ID 추가
  if (params.parentClipId) {
    clip.parentClipId = params.parentClipId;
  }

  return clip;
}

/**
 * 🖼️ Image 클립 생성
 * - 시각적 속성만 포함
