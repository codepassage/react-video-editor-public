generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                  @id @default(uuid())
  email             String?                 @unique
  name              String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  autoGenProjects   AutoGenerationProject[]
  csvColumnMaps     CsvColumnMap[]
  projects          Project[]
  resourceData      ResourceData[]
  resourceTemplates ResourceTemplate[]
  templates         Template[]
}

model TemplateType {
  id          String     @id @default(uuid())
  name        String
  description String     @default("")
  createdAt   DateTime   @default(now())
  templates   Template[]

  @@index([name])
}

model Template {
  id                  String                          @id @default(uuid())
  name                String                          @unique
  description         String                          @default("")
  userId              String?
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  totalClips          Int                             @default(0)
  totalTracks         Int                             @default(0)
  duration            Float                           @default(0)
  typeId              String
  screenshotPath      String?
  autoGenProjects     AutoGenerationProject[]
  bundles             Bundle[]
  projects            Project[]
  type                TemplateType                    @relation(fields: [typeId], references: [id])
  user                User?                           @relation(fields: [userId], references: [id])
  templateGroups      TemplateGroup[]
  versions            TemplateVersion[]
  compatibleResources TemplateResourceCompatibility[]

  @@index([name])
  @@index([createdAt])
  @@index([typeId])
}

model TemplateVersion {
  id            String   @id @default(uuid())
  templateId    String
  projectData   Json
  version       Int      @default(1)
  versionString String   @default("1.0.0")
  createdAt     DateTime @default(now())
  template      Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId, version])
}

model Bundle {
  id               String   @id @default(uuid())
  name             String
  color            String
  templateId       String
  startTime        Float
  endTime          Float
  baseClipIds      Json
  templateGroupIds Json
  createdAt        DateTime @default(now())
  template         Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model TemplateGroup {
  id          String   @id @default(uuid())
  name        String
  templateId  String
  clipIds     Json
  startTime   Float
  endTime     Float
  isProtected Boolean  @default(false)
  color       String
  bundleId    String?
  createdAt   DateTime @default(now())
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model MediaFile {
  id           String    @id @default(uuid())
  filename     String    @unique
  originalName String
  mimetype     String
  size         Int
  mediaType    MediaType
  url          String
  thumbnailUrl String?
  width        Int?
  height       Int?
  duration     Float?
  metadata     Json?
  uploadedAt   DateTime  @default(now())
  deletedAt    DateTime?

  @@index([mediaType])
  @@index([uploadedAt])
  @@index([filename])
}

model RenderResult {
  id              String       @id @default(uuid())
  filename        String       @unique
  originalRequest Json
  status          RenderStatus @default(PENDING)
  progress        Float        @default(0)
  duration        Float?
  size            Int?
  url             String?
  errorMessage    String?
  templateId      String?
  projectId       String?
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  @@index([status])
  @@index([createdAt])
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  templateId  String?
  userId      String?
  projectData Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  template    Template? @relation(fields: [templateId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@index([name])
  @@index([createdAt])
}

model ResourceData {
  id                  String                          @id @default(uuid())
  name                String                          @unique
  description         String?
  itemCount           Int                             @default(0)
  hasNested           Boolean                         @default(false)
  maxDepth            Int                             @default(0)
  userId              String?
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  csvMapId            String?
  resourceTemplateId  String?                         @unique
  autoGenProjects     AutoGenerationProject[]
  csvColumnMap        CsvColumnMap?                   @relation("CsvColumnMapToResourceData", fields: [csvMapId], references: [id])
  resourceTemplate    ResourceTemplate?               @relation("ResourceTemplateToResourceData", fields: [resourceTemplateId], references: [id])
  user                User?                           @relation(fields: [userId], references: [id])
  versions            ResourceDataVersion[]
  compatibleTemplates TemplateResourceCompatibility[]

  @@index([name])
  @@index([createdAt])
  @@index([hasNested])
  @@index([resourceTemplateId])
  @@index([csvMapId])
}

model ResourceDataVersion {
  id             String       @id @default(uuid())
  resourceDataId String
  data           Json
  version        Int          @default(1)
  versionString  String       @default("1.0.0")
  createdAt      DateTime     @default(now())
  resourceData   ResourceData @relation(fields: [resourceDataId], references: [id], onDelete: Cascade)

  @@unique([resourceDataId, version])
  @@index([resourceDataId, version])
}

model Script {
  id            String         @id @default(uuid())
  content       String
  language      String         @default("ko")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  audioMappings AudioMapping[]
}

model AudioMapping {
  id        String   @id @default(uuid())
  scriptId  String
  audioPath String
  ttsConfig Json?
  createdAt DateTime @default(now())
  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
}

model ResourceTemplate {
  id                  String                    @id @default(uuid())
  name                String                    @unique
  description         String?
  itemCount           Int                       @default(0)
  hasNested           Boolean                   @default(false)
  maxDepth            Int                       @default(0)
  userId              String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  csvColumnMaps       CsvColumnMap[]
  resourceData        ResourceData?             @relation("ResourceTemplateToResourceData")
  user                User?                     @relation(fields: [userId], references: [id])
  versions            ResourceTemplateVersion[]

  @@index([name])
  @@index([createdAt])
  @@index([hasNested])
}

model ResourceTemplateVersion {
  id                 String           @id @default(uuid())
  resourceTemplateId String
  templateData       Json
  version            Int              @default(1)
  versionString      String           @default("1.0.0")
  createdAt          DateTime         @default(now())
  resourceTemplate   ResourceTemplate @relation(fields: [resourceTemplateId], references: [id], onDelete: Cascade)

  @@unique([resourceTemplateId, version])
  @@index([resourceTemplateId, version])
}

model CsvColumnMap {
  id                  String                  @id @default(uuid())
  name                String                  @unique
  description         String?
  resourceTemplateId  String?
  columnCount         Int                     @default(0)
  mappingComplexity   String                  @default("simple")
  userId              String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  autoGenProjects     AutoGenerationProject[]
  resourceTemplate    ResourceTemplate?       @relation(fields: [resourceTemplateId], references: [id])
  user                User?                   @relation(fields: [userId], references: [id])
  versions            CsvColumnMapVersion[]
  resourceDataEntries ResourceData[]          @relation("CsvColumnMapToResourceData")

  @@index([name])
  @@index([createdAt])
  @@index([resourceTemplateId])
  @@index([mappingComplexity])
}

model CsvColumnMapVersion {
  id            String       @id @default(uuid())
  csvMapId      String
  mappingData   Json
  version       Int          @default(1)
  versionString String       @default("1.0.0")
  createdAt     DateTime     @default(now())
  csvColumnMap  CsvColumnMap @relation(fields: [csvMapId], references: [id], onDelete: Cascade)

  @@unique([csvMapId, version])
  @@index([csvMapId, version])
}

model TemplateResourceCompatibility {
  id         String       @id @default(uuid())
  templateId String
  resourceId String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  resource   ResourceData @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  template   Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, resourceId])
  @@map("template_resource_compatibility")
}

model AutoGenerationProject {
  id              String          @id @default(uuid())
  name            String
  templateId      String?
  resourceId      String?
  csvMapId        String?
  userId          String?
  transformResult Json?
  status          String          @default("draft")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  csvMap          CsvColumnMap?   @relation(fields: [csvMapId], references: [id])
  resource        ResourceData?   @relation(fields: [resourceId], references: [id])
  template        Template?       @relation(fields: [templateId], references: [id])
  user            User?           @relation(fields: [userId], references: [id])
  renderJobs      RenderJob[]
  youtubeUploads  YouTubeUpload[]
}

model RenderJob {
  id             String                @id @default(uuid())
  projectId      String
  renderSettings Json
  status         String                @default("pending")
  progress       Int                   @default(0)
  outputPath     String?
  metadata       Json?
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime              @default(now())
  project        AutoGenerationProject @relation(fields: [projectId], references: [id])
  youtubeUpload  YouTubeUpload?
}

model YouTubeUpload {
  id             String                @id @default(uuid())
  projectId      String
  renderJobId    String?               @unique
  videoPath      String
  title          String
  description    String?
  tags           String[]
  thumbnail      String?
  scheduledAt    DateTime
  publishAt      DateTime?
  privacy        String                @default("private")
  status         String                @default("scheduled")
  youtubeVideoId String?
  uploadProgress Int                   @default(0)
  error          String?
  uploadedAt     DateTime?
  createdAt      DateTime              @default(now())
  project        AutoGenerationProject @relation(fields: [projectId], references: [id])
  renderJob      RenderJob?            @relation(fields: [renderJobId], references: [id])
}

model TTSDefaultVoice {
  id           String   @id @default(uuid())
  languageCode String   @unique
  voiceName    String
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([languageCode])
  @@index([isActive])
}

enum MediaType {
  image
  video
  audio
  unknown
}

enum RenderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
