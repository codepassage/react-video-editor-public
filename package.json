{
  "name": "react-video-editor",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.ts",
    "bundle": "remotion bundle src/render/index.ts",
    "build": "remotion bundle src/Root.tsx && tsc && vite build",
    "build:server": "tsc --project server/tsconfig.json",
    "start:server": "node server/dist/index.js",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "remotion:dev": "remotion studio",
    "remotion:render": "remotion render",
    "remotion:preview": "remotion preview",
    "extract-metadata": "ts-node scripts/extract-metadata.ts",
    "render:json": "ts-node scripts/renderFromJSON.ts",
    "render:json:build": "tsc scripts/renderFromJSON.ts && node scripts/renderFromJSON.js",
    "render:batch": "ts-node scripts/batchRender.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.11.0",
    "@bull-board/express": "^6.11.0",
    "@google-cloud/storage": "^7.16.0",
    "@google-cloud/text-to-speech": "^6.1.0",
    "@prisma/client": "^6.10.1",
    "@remotion/player": "4.0.306",
    "@remotion/renderer": "4.0.306",
    "@types/bull": "^3.15.9",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/papaparse": "^5.3.16",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.7.2",
    "bull": "^4.16.5",
    "bull-board": "^1.2.0",
    "bullmq": "^5.56.1",
    "clsx": "^2.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.2.0",
    "googleapis": "^150.0.1",
    "jsoneditor": "^10.2.0",
    "lucide-react": "^0.293.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.0",
    "openai": "^5.8.2",
    "papaparse": "^5.5.3",
    "prisma": "^6.10.1",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.6.2",
    "remotion": "4.0.306",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "vanilla-jsoneditor": "^3.6.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@remotion/bundler": "^4.0.306",
    "@remotion/cli": "^4.0.306",
    "@stagewise/toolbar": "^0.6.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "globals": "^13.23.0",
    "jest": "^30.0.4",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.2.2",
    "vite": "^5.4.19"
  }
}
