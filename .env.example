# 서버 포트 설정
VITE_PORT=3004
VITE_BACKEND_PORT=5002

# 백엔드 호스트 설정 (개발 환경에서 외부 접속 허용)
VITE_BACKEND_HOST=localhost

# API URL (포트는 VITE_BACKEND_PORT와 자동 조합됨)
VITE_API_URL=http://localhost

# 폰트 서버 URL (포트는 VITE_BACKEND_PORT와 자동 조합됨, 기본적으로 API_URL과 동일)
VITE_FONT_SERVER_URL=http://localhost

# 개발 환경 설정
NODE_ENV=development

# 프로덕션 환경에서는 실제 서버 URL로 변경
# VITE_API_URL=https://your-production-server.com
# VITE_PORT=80
# VITE_BACKEND_PORT=8080


# This was inserted by `prisma init`:
# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/youtube_generator"

# Google Cloud TTS 설정
GOOGLE_APPLICATION_CREDENTIALS=server/secret/service-account.json
TTS_CACHE_DIR=server/uploads/tts

# Whisper 서비스 설정
# Whisper 프로바이더 선택: 'local' | 'openai' | 'remote' | 'auto' (기본값: 'local')
WHISPER_PROVIDER=local

# OpenAI API 설정 (Whisper 자막 생성용)
# OpenAI 대시보드에서 API 키를 발급받아 설정하세요
# OPENAI_API_KEY="your_openai_api_key_here"
WHISPER_MODEL=whisper-1

# 로컬 Whisper 설정
# 로컬 Whisper 명령어 (기본값: 'whisper')
LOCAL_WHISPER_COMMAND=whisper
# 로컬 Whisper 모델 크기: tiny, base, small, medium, large, large-v1, large-v2, large-v3, large-v3-turbo
# tiny: 39MB (매우 빠름, 낮은 정확도)
# base: 74MB (빠름, 보통 정확도)
# small: 244MB (보통 속도, 좋은 정확도)
# medium: 769MB (느림, 매우 좋은 정확도)
# large: 1550MB (매우 느림, 최고 정확도)
# large-v3-turbo: 809MB (빠름 + 높은 정확도, 권장)
# 기본값: 'medium'
LOCAL_WHISPER_MODEL_SIZE=medium
# 로컬 Whisper 모델 파일 경로 (선택사항, 비워두면 자동 다운로드)
# LOCAL_WHISPER_MODEL_PATH=/path/to/model.pt

# 원격 Whisper 서버 설정 (WHISPER_PROVIDER=remote 시 필수)
# FastAPI 기반 Whisper 서버 URL (POST /transcribe 엔드포인트 제공)
# REMOTE_WHISPER_URL=http://localhost:8001
# 원격 서버 요청 타임아웃 (밀리초, 기본값: 300000 = 5분)
# REMOTE_WHISPER_TIMEOUT=300000

# Whisper 캐시 디렉터리
WHISPER_CACHE_DIR=server/uploads/whisper

# Redis (for Bull Queue)
REDIS_URL="redis://localhost:6379"

# YouTube API Configuration
# Get these from Google Cloud Console -> APIs & Services -> Credentials
# YOUTUBE_CLIENT_ID="your_youtube_client_id_here"
# YOUTUBE_CLIENT_SECRET="your_youtube_client_secret_here" 
# YOUTUBE_REDIRECT_URI="http://localhost:3010/youtube/callback"

# 디버깅 설정
VITE_CSS_DEBUG=false
VITE_CLIP_DEBUG=false